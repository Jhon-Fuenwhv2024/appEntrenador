# Vite carga automáticamente:
# - `.env.development` en `npm run dev`
# - `.env.production` en `npm run build` / deploy
#
# Además, `src/config/api.js` detecta el host del navegador:
# - localhost → http://localhost:3000/api
# - desplegado → VITE_API_URL (si no es localhost) o Render por defecto

# Desarrollo (opcional; ya está en `.env.development`)
VITE_API_URL=http://localhost:3000/api

# Producción: ver `.env.production`
# VITE_API_URL=https://appentrenador.onrender.com/api
