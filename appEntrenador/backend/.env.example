# Copiar a .env y ajustar. No commitear .env.
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=8h
PORT=3000

# MySQL (local XAMPP por defecto; en Render/TiDB usa tu DB gestionada)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=coach_db
# TiDB Serverless ejemplo:
# DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# DB_USER=xxxx.root
# DB_PASSWORD=
# DB_NAME=coach_db
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Frontend público (reset password + CORS)
APP_PUBLIC_URL=http://localhost:5173
# Orígenes permitidos separados por coma (Workers.dev, túnel, etc.).
# En desarrollo, localhost:5173/4173 se añaden solos aunque no estén aquí.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Resend Free Tier — SMTP (Nodemailer; no requiere SDK)
# Host/user fijos; SMTP_PASS = API key (re_...)
# onboarding@resend.dev solo envía al email de la cuenta Resend.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_PEGA_AQUI_TU_API_KEY
SMTP_FROM=Trainfit <noreply@trainfit.co>
