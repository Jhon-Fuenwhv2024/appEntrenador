# Copiar a .env y ajustar. No commitear .env.
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=8h
PORT=3000

# URL pública del frontend (enlace de reset de contraseña)
APP_PUBLIC_URL=http://localhost:5173

# Resend Free Tier — SMTP (Nodemailer; no requiere SDK)
# Host/user fijos; SMTP_PASS = API key (re_...)
# onboarding@resend.dev solo envía al email de la cuenta Resend.
# Con dominio verificado: SMTP_FROM=Trainfit <noreply@tudominio.com>
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_PEGA_AQUI_TU_API_KEY
SMTP_FROM=Trainfit <noreply@trainfit.co>
