{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "entrenadorfit",
  "compatibility_date": "2026-07-20",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  // Static SPA: serve Vite build output (never upload raw /src).
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
